// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Models

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  address   String?
  notes     String?
  status    ClientStatus @default(active)
  company   String?
  tax_id    String?
  user_id   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  user         User?          @relation(fields: [user_id], references: [id])
  appointments Appointment[]
  invoices     Invoice[]
  formResponses FormResponse[]
  sharedCases  SharedCase[]

  @@map("clients")
}

model Appointment {
  id            String   @id @default(cuid())
  client_id     String
  service_type  String
  date          String // ISO date string
  time          String // HH:MM format
  duration      Int
  status        AppointmentStatus @default(scheduled)
  notes         String?
  client_notes  String?
  price         Float?
  user_id       String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  client     Client     @relation(fields: [client_id], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [user_id], references: [id])
  invoices   Invoice[]

  @@map("appointments")
}

model Invoice {
  id            String   @id @default(cuid())
  client_id     String
  appointment_id String?
  invoice_number String   @unique
  issue_date     String // ISO date
  due_date       String // ISO date
  status         InvoiceStatus @default(draft)
  subtotal       Float
  tax_rate       Float
  tax_amount     Float
  total          Float
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  client      Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointment_id], references: [id])
  items       InvoiceItem[]
  transactions Transaction[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoice_id  String
  description String
  quantity    Int
  unit_price  Float
  total       Float
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Form {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  is_active   Boolean  @default(true)
  fields      Json // FormField[] as JSON
  user_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  user      User?          @relation(fields: [user_id], references: [id])
  responses FormResponse[]

  @@map("forms")
}

model FormResponse {
  id         String  @id @default(cuid())
  form_id    String
  client_id  String
  responses  Json // Record<string, any> as JSON
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  form   Form   @relation(fields: [form_id], references: [id], onDelete: Cascade)
  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("form_responses")
}

model Transaction {
  id             String  @id @default(cuid())
  type           TransactionType
  category       String
  description    String
  amount         Float
  date           String // ISO date
  payment_method PaymentMethod
  invoice_id     String?
  user_id        String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  invoice Invoice? @relation(fields: [invoice_id], references: [id])
  user    User?    @relation(fields: [user_id], references: [id])

  @@map("transactions")
}

// User model for authentication and role management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String? // For credentials provider (hashed)
  image     String?
  subdomain String?  @unique
  role_id   String
  is_active Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  role                 Role           @relation(fields: [role_id], references: [id])
  clients              Client[]
  appointments         Appointment[]
  forms                Form[]
  transactions         Transaction[]
  communityTests       CommunityTest[]
  sentConnections      Connection[]   @relation("SentConnections")
  receivedConnections  Connection[]   @relation("ReceivedConnections")
  sharedCasesSent      SharedCase[]   @relation("SharedCasesSent")
  sharedCasesReceived  SharedCase[]   @relation("SharedCasesReceived")

  @@map("users")
}

// Role model for authorization
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., 'admin', 'sekreter', 'asistan'
  description String?
  permissions Json? // Store permissions as JSON
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  users User[]

  @@map("roles")
}

// Community test sharing
model CommunityTest {
  id          String   @id @default(cuid())
  title       String
  description String?
  questions   Json
  author_id   String
  is_public   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  author User @relation(fields: [author_id], references: [id])

  @@map("community_tests")
}

// Colleague connections
model Connection {
  id           String           @id @default(cuid())
  requester_id String
  addressee_id String
  status       ConnectionStatus @default(PENDING)
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  // Relations
  requester User @relation("SentConnections", fields: [requester_id], references: [id])
  addressee User @relation("ReceivedConnections", fields: [addressee_id], references: [id])

  @@unique([requester_id, addressee_id])
  @@map("connections")
}

// Shared cases between colleagues
model SharedCase {
  id                  String      @id @default(cuid())
  client_id           String
  shared_by_user_id   String
  shared_with_user_id String
  access_level        AccessLevel @default(READ)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  // Relations
  client      Client @relation(fields: [client_id], references: [id])
  shared_by   User   @relation("SharedCasesSent", fields: [shared_by_user_id], references: [id])
  shared_with User   @relation("SharedCasesReceived", fields: [shared_with_user_id], references: [id])

  @@unique([client_id, shared_by_user_id, shared_with_user_id])
  @@map("shared_cases")
}

// Enums

enum ClientStatus {
  active
  inactive
  prospect
}

enum AppointmentStatus {
  scheduled
  completed
  cancelled
  no_show
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  cash
  bank
  card
  transfer
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
}

enum AccessLevel {
  READ
  WRITE
}
